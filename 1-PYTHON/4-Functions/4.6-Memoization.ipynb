   "source": [
    "def fact(n,memos={}):\n",
    "    if n in memos :\n",
    "        return memos[n]\n",
    "    if n==0 :\n",
    "        memos[n]=1\n",
    "        return 1\n",
    "    memos[n] = n*fact(n-1,memos)\n",
    "    print(memos)\n",
    "    return memos[n]\n",
    "print(fact(6)) \n",
    "print(fact(8)) \n",
    "print(fact(4)) \n",
    "print(fact(3)) "
   ]
  },
